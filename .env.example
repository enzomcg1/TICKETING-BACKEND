DATABASE_URL=postgresql://user:password@host:5432/ticketing?schema=public
JWT_SECRET=replace-with-at-least-32-characters
JWT_EXPIRES_IN=7d
PORT=3000
NODE_ENV=development

FRONTEND_URL=http://localhost:5173
FRONTEND_ORIGIN_PATTERNS=https://*.vercel.app

ENABLE_SOCKET_NOTIFICATIONS=false
ENABLE_EMAIL_NOTIFICATIONS=false

SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_SECURE=false
EMAIL_USER=notifications@example.com
EMAIL_PASSWORD=replace-with-smtp-password
SMTP_FROM_NAME=Sistema de Tickets
SMTP_FROM_EMAIL=notifications@example.com

TEST_EMAIL=owner@example.com
